@model HtmlToPdf.Models.ConvertViewModel
@{
    ViewData["Title"] = "HTML to PDF Converter";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="mb-3">HTML to PDF Converter</h2>
            <p class="text-muted">Convert HTML to PDF — no browser engine required.</p>

            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Source Tabs -->
            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-single" type="button">
                        Single File
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-batch" type="button">
                        Batch Convert
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Single File Tab -->
                <div class="tab-pane fade show active" id="tab-single">
                    <form asp-action="Convert" method="post" enctype="multipart/form-data">
                        <ul class="nav nav-pills mb-3" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-html"
                                        type="button" onclick="document.getElementById('ConversionSource').value='html'">
                                    HTML Editor
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-file"
                                        type="button" onclick="document.getElementById('ConversionSource').value='file'">
                                    File Upload
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-url"
                                        type="button" onclick="document.getElementById('ConversionSource').value='url'">
                                    URL
                                </button>
                            </li>
                        </ul>

                        <input type="hidden" id="ConversionSource" name="ConversionSource" value="@Model?.ConversionSource" />

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="tab-html">
                                <textarea name="HtmlContent" class="form-control font-monospace" rows="14"
                                          placeholder="Enter your HTML here...">@Model?.HtmlContent</textarea>
                            </div>
                            <div class="tab-pane fade" id="tab-file">
                                <div class="border rounded p-4 text-center bg-light">
                                    <input type="file" name="HtmlFile" class="form-control" accept=".html,.htm,.xhtml" />
                                    <small class="text-muted mt-2 d-block">Accepted formats: .html, .htm, .xhtml</small>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="tab-url">
                                <input type="url" name="Url" class="form-control" value="@Model?.Url"
                                       placeholder="https://example.com" />
                            </div>
                        </div>

                        @await Html.PartialAsync("_PdfSettings", Model)

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary btn-lg">Convert to PDF</button>
                        </div>
                    </form>
                </div>

                <!-- Batch Convert Tab -->
                <div class="tab-pane fade" id="tab-batch">
                    <form asp-action="BatchConvert" method="post" enctype="multipart/form-data">
                        <div class="border rounded p-4 bg-light">
                            <label class="form-label fw-bold">Upload multiple HTML files</label>
                            <input type="file" name="HtmlFiles" class="form-control" accept=".html,.htm,.xhtml" multiple />
                            <small class="text-muted mt-2 d-block">
                                Select multiple files. Each will be converted in parallel using all CPU cores
                                (@Environment.ProcessorCount cores available). Output: ZIP with all PDFs.
                            </small>
                        </div>

                        @await Html.PartialAsync("_PdfSettings", Model)

                        <div class="mt-3">
                            <button type="submit" class="btn btn-success btn-lg">Batch Convert to ZIP</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
